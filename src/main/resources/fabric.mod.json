{
  "schemaVersion": 1,
  "id": "orekas",
  "version": "${version}",
  "name": "Orekas",
  "description": "Ore-vein ESP for Meteor Client, powered by orefinder.gg's WASM model with live-world validation and an anti-xray fallback heuristic.",
  "authors": [
    "Webrekas"
  ],
  "contact": {
    "sources": "https://github.com/furkankoykiran/Orekas",
    "issues": "https://github.com/furkankoykiran/Orekas/issues"
  },
  "license": "GPL-3.0-only",
  "icon": "assets/orekas/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.webrekas.addon.OrekasAddon"
    ]
  },
  "mixins": [
    "orekas.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
